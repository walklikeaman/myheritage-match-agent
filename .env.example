# Copy to .env and fill in values
# Never commit .env to git

# Path to exported cookies JSON (from EditThisCookie or similar)
COOKIES_FILE=data/myheritage_cookies.json

# Path to Playwright session state (auto-generated after first login)
SESSION_FILE=data/myheritage_session.json

# Confidence threshold for auto-accepting matches (0-100)
CONFIDENCE_THRESHOLD=80

# Max matches to process per session (safety cap)
MAX_MATCHES_PER_SESSION=200

# Optional: MyHeritage credentials for re-auth fallback
# MH_EMAIL=your@email.com
# MH_PASSWORD=yourpassword

# Optional: Family Graph API (for future read operations)
# MYHERITAGE_APP_KEY=
# MYHERITAGE_BEARER_TOKEN=
